# Claude API
ANTHROPIC_API_KEY=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=

# Slack Socket Mode（質問応答 bot 用、Phase 1+）
SLACK_APP_TOKEN=xapp-...

# 動作モード ("true" にすると Slack 投稿せず stdout に出力)
DRY_RUN=true

# shiroco v2 RAG サーバー（Mac mini 常駐 FastAPI、itaco とは別サービス）
# ConoHa 経由: https://app.instyle.group/shiroco
# Tailscale 直: http://itacomac-mini.tailcba5f2.ts.net:8789
# 未設定なら bot は「shiroco v2 未接続」として persona 圧縮版 + web_search で応答継続する
SHIROCO_V2_BASE_URL=
SHIROCO_V2_API_KEY=
